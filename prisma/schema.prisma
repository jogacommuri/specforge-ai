// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Projects belong to users
model Project {
  id          String       @id @default(uuid())
  name        String
  description String?      @db.Text
  userId      String       // Clerk user ID
  artifacts   Artifact[]
  runs        PipelineRun[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([createdAt])
}

// Artifacts store generated outputs (requirements, API design, tests)
model Artifact {
  id        String   @id @default(uuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  type      String   // "requirements" | "api" | "tests"
  version   Int      @default(1)
  content   Json     // Store the actual artifact data
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([projectId, type, version])
}

// Pipeline runs belong to projects
model PipelineRun {
  id            String   @id @default(uuid())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  feature       String   @db.Text
  status        String   // "running" | "completed" | "error"
  totalDuration Int?     // milliseconds
  totalTokens   Int?
  totalCost     Decimal? @db.Decimal(10, 6)
  confidence    Decimal? @db.Decimal(3, 2) // Overall confidence score
  deltaSummary  String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agents PipelineAgent[]

  @@index([projectId])
  @@index([createdAt])
}

// Individual agent execution records
model PipelineAgent {
  id            String      @id @default(uuid())
  pipelineRunId String
  name          String      // "Requirements", "API Design", etc.
  status        String      // "idle" | "running" | "completed" | "error"
  duration      Int?        // milliseconds
  confidence    Decimal?    @db.Decimal(3, 2) // 0.00 to 1.00
  attempts      Int?
  tokens        Int?
  cost          Decimal?    @db.Decimal(10, 6)
  data          Json?       // Store agent output data
  createdAt     DateTime    @default(now())

  pipelineRun PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)

  @@unique([pipelineRunId, name]) // Ensure one agent per name per run
  @@index([pipelineRunId])
}
